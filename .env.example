# Copy to .env and fill in your Epic sandbox credentials.
# .env is gitignored — never commit real secrets.

# The client_id registered in the Epic on FHIR developer portal.
EPIC_CLIENT_ID=your-registered-client-id

# Path to the PEM-encoded RSA private key whose public key is registered
# with Epic for the client_id above.
EPIC_PRIVATE_KEY_PATH=/absolute/path/to/private_key.pem

# Alternatively, supply the PEM contents inline (takes precedence over the path):
# EPIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
